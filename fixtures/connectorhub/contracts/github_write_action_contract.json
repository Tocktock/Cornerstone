{
  "schema_version": "cornerstone.connector_contract.v1",
  "contract_id": "ccon_project_alpha_github_write_attempt",
  "contract_version": "1.0.0",
  "scope": {
    "tenant_id": "local-dev",
    "owner_id": "local-user",
    "namespace_id": "personal",
    "workspace_id": "default"
  },
  "purpose": "Negative fixture: attempt to declare GitHub write actions that must be rejected.",
  "needs": [
    {
      "common_capability": "source_control.issue.read",
      "required": true,
      "accepted_projection_types": [
        "source_control.issue.v1"
      ]
    }
  ],
  "source_policy_request": {
    "selected_resources": [
      "github:repo:owner/project-alpha"
    ],
    "content_mode": "metadata_and_markdown_excerpt",
    "max_content_bytes": 200000,
    "allowed_paths": [
      "docs/**",
      "README.md"
    ],
    "raw_access": "denied",
    "retention_days": 90
  },
  "actions": [
    {
      "id": "github_issue_comment",
      "provider": "github",
      "action_type": "issue.comment",
      "method": "POST",
      "endpoint": "/repos/owner/project-alpha/issues/1001/comments"
    },
    {
      "id": "github_pr_merge",
      "provider": "github",
      "action_type": "pull_request.merge",
      "method": "PUT",
      "endpoint": "/repos/owner/project-alpha/pulls/7/merge"
    }
  ],
  "delivery": {
    "ack_required": true,
    "retry_policy": "bounded_exponential",
    "quarantine_after_attempts": 3
  }
}
