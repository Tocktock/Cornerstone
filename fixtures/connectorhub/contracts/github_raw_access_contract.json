{
  "schema_version": "cornerstone.connector_contract.v1",
  "contract_id": "ccon_project_alpha_github_raw_access",
  "contract_version": "1.0.0",
  "scope": {
    "tenant_id": "local-dev",
    "owner_id": "local-user",
    "namespace_id": "personal",
    "workspace_id": "default"
  },
  "purpose": "Allow tightly bounded diagnostic raw-source inspection for selected read-only source-control evidence.",
  "needs": [
    {
      "common_capability": "source_control.repository.read",
      "required": true,
      "accepted_projection_types": [
        "source_control.repository.v1"
      ]
    },
    {
      "common_capability": "source_control.issue.read",
      "required": true,
      "accepted_projection_types": [
        "source_control.issue.v1"
      ]
    }
  ],
  "source_policy_request": {
    "selected_resources": [
      "github:repo:owner/project-alpha"
    ],
    "content_mode": "metadata_and_markdown_excerpt",
    "max_content_bytes": 200000,
    "allowed_paths": [
      "docs/**",
      "README.md"
    ],
    "raw_access": "temporary_scoped",
    "raw_access_policy": {
      "max_ttl_seconds": 60,
      "max_reads": 1,
      "allowed_purposes": [
        "diagnose_ingestion_gap"
      ],
      "handle_redaction_required": true,
      "raw_content_not_copied_to_product": true,
      "revocable": true
    },
    "retention_days": 7
  },
  "actions": [],
  "delivery": {
    "ack_required": true,
    "retry_policy": "bounded_exponential",
    "quarantine_after_attempts": 3
  }
}
