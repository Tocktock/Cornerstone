# Cornerstone backend local/runtime ignores.
#
# Keep the backend release package trackable, including docs, tests, migrations,
# scripts, and sanitized files under cornerstone-backend/reports/.

# Secrets and local environment files
.env
.env.*
**/.env
**/.env.*
!.env.example
!**/.env.example

# Python bytecode and interpreter caches
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
**/.venv/
**/venv/
**/env/

# Test, lint, type-check, and coverage runtime output
.coverage
.coverage.*
**/.coverage
**/.coverage.*
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.hypothesis/
htmlcov/
.cache/
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
**/htmlcov/

# Python build and packaging output
build/
dist/
*.egg-info/
.eggs/
*.egg
pip-wheel-metadata/
site/

# Local databases, scratch data, and runtime files
*.sqlite
*.sqlite3
*.db
*.db-shm
*.db-wal
/data/
/tmp/
/temp/
/var/
/local-data/
/cornerstone-backend/data/
/cornerstone-backend/tmp/
/cornerstone-backend/temp/
/cornerstone-backend/var/
/cornerstone-backend/local-data/

# Logs and local process files
*.log
*.pid
*.pid.lock

# Sanitized release reports are part of the backend artifact.
!cornerstone-backend/reports/
!cornerstone-backend/reports/**

# Docker/local service state
.docker/
docker-data/
postgres-data/
pgdata/
qdrant_storage/

# OS and editor metadata
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# Tool-specific local state
.python-version
.ruff_cache/
.mypy_cache/
.pytest_cache/
.serena/
