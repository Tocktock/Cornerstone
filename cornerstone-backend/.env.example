# Local development defaults are intentionally non-production.
# Production mode fails closed unless postgres/live provider/secret settings are safe.
APP_ENV=local
PRODUCTION_MODE=false
API_PREFIX=/v1
FRESHNESS_FRESH_DAYS=7
FRESHNESS_STALE_DAYS=30
LOG_LEVEL=INFO
AUTHORIZED_REVIEWERS_RAW=system,reviewer@example.com

# Persistence. Use memory for fast local API contract tests; use postgres for production/dev DB.
PERSISTENCE_BACKEND=memory
DATABASE_URL=postgresql+psycopg://cornerstone:cornerstone@localhost:5432/cornerstone
DATABASE_ECHO=false
POSTGRES_REQUIRED_EXTENSIONS_RAW=pgcrypto,citext,vector
VERIFY_POSTGRES_EXTENSIONS_ON_STARTUP=true

# Connector runtime. Replace this with a long secret before enabling PRODUCTION_MODE=true.
CONNECTOR_INTENT_TTL_MINUTES=15
CONNECTOR_ENCRYPTION_SECRET=local-dev-only-change-me-secret
CONNECTOR_OAUTH_CALLBACK_URL=http://localhost:8000/v1/oauth/notion/callback
CONNECTOR_HTTP_TIMEOUT_SECONDS=10.0

# Notion connector. Keep mock mode true for local contract tests; set false for live provider calls.
NOTION_CLIENT_ID=local-notion-client-id
NOTION_CLIENT_SECRET=local-notion-client-secret
NOTION_OAUTH_AUTHORIZE_URL=https://api.notion.com/v1/oauth/authorize
NOTION_OAUTH_TOKEN_URL=https://api.notion.com/v1/oauth/token
NOTION_API_BASE_URL=https://api.notion.com/v1
NOTION_VERSION=2026-03-11
NOTION_MOCK_EXTERNAL_API=true
NOTION_USE_MARKDOWN_ENDPOINT=true
NOTION_BLOCK_PAGE_SIZE=100
NOTION_MAX_BLOCK_DEPTH=3
