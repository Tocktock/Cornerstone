POSTGRES_DB=cornerstone
POSTGRES_USER=cornerstone
POSTGRES_PASSWORD=cornerstone

CORNERSTONE_DATABASE_URL=postgresql+psycopg://cornerstone:cornerstone@db:5432/cornerstone
# Runtime mode options: mock | production
# - mock: demo content and demo connector fallback may be used
# - production: demo content and demo connector fallback are disabled
CORNERSTONE_RUNTIME_MODE=mock
CORNERSTONE_FIXTURE_ROOT=/workspace/fixtures
CORNERSTONE_WORKSPACE_SOURCE_ROOT=/workspace/fixtures/minimal/workspace/member-visible
CORNERSTONE_PERSONAL_SOURCE_ROOT=/workspace/fixtures/minimal/personal/member-private
CORNERSTONE_NOTION_FIXTURE_ROOT=/workspace/fixtures/notion
CORNERSTONE_CORPUS_SOURCE_ROOT=/workspace/sample-data/sendy-knowledge
# Transitional compatibility input. Runtime mode remains the primary source of truth.
CORNERSTONE_AUTO_SEED_DEMO=true
CORNERSTONE_RESET_DATABASE_ON_START=false
CORNERSTONE_FIXED_NOW=2026-04-06T09:00:00+09:00
CORNERSTONE_FRONTEND_BASE_URL=http://localhost:5173
# Transitional compatibility input. Intended only for mock runtime.
CORNERSTONE_NOTION_DEMO_OAUTH_MODE=true
CORNERSTONE_NOTION_CLIENT_ID=
CORNERSTONE_NOTION_CLIENT_SECRET=
CORNERSTONE_NOTION_OAUTH_REDIRECT_URI=
CORNERSTONE_CORS_ORIGINS=["http://localhost:5173"]

VITE_API_BASE_URL=http://localhost:8000/api/v1
